# Copy to .env.local. Never commit .env.local.
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Required in both Next.js and the linked Convex deployment.
# This was added during the write-auth hardening pass.
INTERNAL_JOB_SECRET=replace-with-a-long-random-secret

# LLM extraction (OpenAI or an OpenAI-compatible provider).
LLM_API_KEY=
# OPENAI_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o
# LLM_JSON_MODE=true
# LLM_MAX_COMPLETION_TOKENS=8192

# Recommended for cascade checks.
# SEMANTIC_SCHOLAR_API_KEY=

# Optional replacement-paper search.
# EXA_API_KEY=

# Usually written by `npx convex dev` / `npx convex deploy`; not required for Vercel runtime.
# CONVEX_DEPLOYMENT=dev:your-project

# Optional Convex site URL; only set if you use Convex site features directly.
# NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site
